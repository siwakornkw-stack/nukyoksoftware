# ---- Database (single PostgreSQL for all modules) ----
DATABASE_URL="postgresql://dhevakij:changeme@localhost:5432/dhevakij?schema=public"

# ---- Auth (JWT app login) ----
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_ACCESS_LIFETIME="7d"

# ---- File storage (local filesystem on the VPS) ----
# Absolute path recommended in production, e.g. /var/lib/dhevakij/uploads
UPLOAD_DIR="./var/uploads"

# ---- Cron (protects /api/cron/* endpoints hit by the worker/crontab) ----
CRON_SECRET="change-me"
# Public origin: used for links the app hands out (e.g. the monthly fuel CSV
# sent to LINE). Set this to the real https:// hostname in production.
APP_BASE_URL="http://127.0.0.1:3000"
# Internal origin the cron worker calls. Only needed when it differs from
# APP_BASE_URL, e.g. when the app sits behind nginx on a non-default port.
CRON_BASE_URL="http://127.0.0.1:3000"

# ---- LINE Messaging API (fuel bot + fleet reminders) ----
# Single-tenant default. Per-tenant tokens can also be stored in the Tenant table.
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
# Fallback admin LINE id for fuel fraud alerts (DB AppSetting 'line_admin_id' wins if set)
LINE_ADMIN_ID=""

# ---- Fuel bill OCR (Google Gemini, AI Studio free tier) ----
GEMINI_API_KEY=""
# Optional: pin one model, blank = fallback chain
EXTRACT_MODEL=""
