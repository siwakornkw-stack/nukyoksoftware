// Unified schema for เทวาวณิชกิจ (dhevakij).
// Core fleet/finance model is carried over from the nukyok project (multi-tenant,
// kept intact; a single default Tenant is seeded). Fuel-bill and Debt/AR models
// are appended below so all three modules share one PostgreSQL database.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

// ======================================================================
// == FLEET & FINANCE (from nukyok) =====================================
// ======================================================================

model DomainName {
  DomainNameId String @id @default(uuid()) @db.VarChar(36)
  TenantId String @db.VarChar(36)
  Tenant Tenant @relation(fields: [TenantId], references: [TenantId])
  HostName String
  Type String @db.VarChar(15)
  @@index([TenantId])
  @@index([HostName])
}

model Tenant {
  TenantId String @id @default(uuid()) @db.VarChar(36)
  Name String
  Status String @db.VarChar(15)
  LineImgUrl String?
  LineChannelAccessToken String?
  LineChannelSecret String?
  SystemExpiredDate DateTime
  Remark String?
  CreatedTime DateTime @default(now())
  UpdatedTime DateTime @default(now())
  Admins Admin[]
  Customers Customer[]
  Settings Setting[]
  DomainName DomainName[]
  RefreshTokens RefreshTokens[] @relation("TenantToRefreshTokens")
  RefreshTokensAdmin RefreshTokensAdmin[] @relation("TenantToRefreshTokensAdmin")
  Vehicles Vehicle[]
  @@index([TenantId])
}

model Admin {
  AdminId String @id @default(uuid()) @db.VarChar(36)
  TenantId String @db.VarChar(36)
  Tenant Tenant @relation(fields: [TenantId], references: [TenantId])
  Status String @db.VarChar(15)
  ImageUrl String?
  Name String?
  Username String
  Password String
  MobileNo String @db.VarChar(50)
  LineId String?
  LineUserId String?
  Email String
  Rank String? @db.VarChar(15)
  LatestIpAddress String @db.VarChar(45)
  LatestLogin DateTime?
  CreatedTime DateTime @default(now())
  CreatedByUsername String @default("auto")
  UpdatedTime DateTime @default(now())
  UpdatedByUsername String?
  DeletedTime DateTime?
  DeletedByUsername String?
  IsOnline Boolean?
  LatestOnline DateTime?
  PasswordHash String
  RefreshTokensAdmin RefreshTokensAdmin[] @relation("AdminToRefreshTokens")
  @@index([TenantId])
  @@index([AdminId])
}

model Customer {
  CustomerId String @id @default(uuid()) @db.VarChar(36)
  TenantId String @db.VarChar(36)
  Tenant Tenant @relation(fields: [TenantId], references: [TenantId])
  Status String @db.VarChar(15)
  Role String @default("admin") @db.VarChar(20)
  ImageUrl String?
  Name String?
  Username String
  Password String
  MobileNo String @db.VarChar(50)
  LineId String?
  LineUserId String?
  LinePinVerify Boolean?
  PinLine String? @db.VarChar(4)
  Email String?
  LatestIpAddress String @db.VarChar(45)
  LatestLogin DateTime?
  CreatedTime DateTime @default(now())
  CreatedByUsername String @default("auto")
  UpdatedTime DateTime?
  UpdatedByUsername String?
  DeletedTime DateTime?
  DeletedByUsername String?
  IsOnline Boolean?
  LatestOnline DateTime?
  PasswordHash String
  RefreshTokens RefreshTokens[] @relation("CustomerToRefreshTokens")
  Notifications Notification[]
  @@index([TenantId])
  @@index([CustomerId])
}

model Notification {
  NotificationId String @id @default(uuid()) @db.VarChar(36)
  CustomerId String @db.VarChar(36)
  Customer Customer @relation(fields: [CustomerId], references: [CustomerId])
  Title String
  Message String
  IsRead Boolean @default(false)
  CreatedTime DateTime @default(now())
  @@index([CustomerId])
}

model Setting {
  SettingConfigId String @id @default(uuid()) @db.VarChar(36)
  TenantId String @db.VarChar(36)
  Tenant Tenant @relation(fields: [TenantId], references: [TenantId])
  Key String
  Value String
  Category String
  @@index([TenantId])
  @@index([SettingConfigId])
}

model RefreshTokens {
  RefreshTokenId String    @id @default(uuid()) @db.VarChar(36)
  HashedToken    String
  Revoked        Boolean   @default(false)
  CreatedTime      DateTime  @default(now())
  UpdatedTime      DateTime?
  CreatedByUsername      String?
  UpdatedByUsername      String?
  CustomerId     String    @db.VarChar(36)
  TenantId     String    @db.VarChar(36)
  Customer       Customer  @relation("CustomerToRefreshTokens", fields: [CustomerId], references: [CustomerId], onDelete: Cascade)
  Tenant       Tenant  @relation("TenantToRefreshTokens", fields: [TenantId], references: [TenantId], onDelete: Cascade)
  @@index([CustomerId, TenantId])
  @@index([RefreshTokenId])
}

model RefreshTokensAdmin {
  RefreshTokenId String    @id @default(uuid()) @db.VarChar(36)
  HashedToken    String
  Revoked        Boolean   @default(false)
  CreatedTime      DateTime  @default(now())
  UpdatedTime      DateTime?
  CreatedByUsername      String?
  UpdatedByUsername      String?
  AdminId     String    @db.VarChar(36)
  TenantId     String    @db.VarChar(36)
  Admin       Admin  @relation("AdminToRefreshTokens", fields: [AdminId], references: [AdminId], onDelete: Cascade)
  Tenant       Tenant  @relation("TenantToRefreshTokensAdmin", fields: [TenantId], references: [TenantId], onDelete: Cascade)
  @@index([AdminId, TenantId])
  @@index([RefreshTokenId])
}

model Vehicle {
  VehicleId String @id @default(uuid()) @db.VarChar(36)
  No Int @default(autoincrement())
  TenantId String @db.VarChar(36)
  Tenant Tenant @relation(fields: [TenantId], references: [TenantId])
  Status String @db.VarChar(15) @default("active")
  LicensePlatePrefix String
  LicensePlateSuffix String
  LicensePlateProvince String
  VehicleType VehicleType? @relation(fields: [VehicleTypeId], references: [VehicleTypeId])
  VehicleTypeId String? @db.VarChar(36)
  VehicleCharacteristic String
  VehicleBrand VehicleBrand? @relation(fields: [VehicleBrandId], references: [VehicleBrandId])
  VehicleBrandId String? @db.VarChar(36)
  Model String
  Generation String
  Color String
  ChassisNumber String
  EngineNumber String
  EngineBrand String
  FuelTypeId String? @db.VarChar(36)
  FuelType FuelType? @relation(fields: [FuelTypeId], references: [FuelTypeId])
  TankSize Int
  FuelConsumption Int
  CylinderCount Int
  Cylinder Int
  VehicleSize String
  CargoSize String
  GasSerialNumber String
  VehicleWeight Int
  CargoWeight Int
  WheelCount Int
  SeatCount Int
  RegistrationDate DateTime?
  StartDate DateTime?
  Age String
  Ownership String
  LineNotifyToken String?
  VehicleOwner VehicleOwner? @relation(fields: [VehicleOwnerId], references: [VehicleOwnerId])
  VehicleOwnerId String? @db.VarChar(36)
  VehicleDepartment VehicleDepartment? @relation(fields: [VehicleDepartmentId], references: [VehicleDepartmentId])
  VehicleDepartmentId String? @db.VarChar(36)
  VehicleDriver VehicleDriver? @relation(fields: [VehicleDriverId], references: [VehicleDriverId])
  VehicleDriverId String? @db.VarChar(36)
  VehicleStatus VehicleStatus? @relation(fields: [VehicleStatusId], references: [VehicleStatusId])
  VehicleStatusId String? @db.VarChar(36)
  InstallmentPeriods Int?
  InstallmentAmount Decimal? @db.Decimal(10,2)
  Note String?
  Img String?
  CreatedAt DateTime @default(now())
  UpdatedAt DateTime @default(now())
  CreatedByUsername String?
  UpdatedByUsername String?
  Tax Tax[]
  CompulsoryMotorInsuranceVehicle CompulsoryMotorInsuranceVehicle[]
  InsurancePolicyVehicle InsurancePolicyVehicle[]
  AttachFileVehicle AttachFileVehicle[]
  CarTires CarTires[]
  AccidentVehicle AccidentVehicle[]
  RepairVehicle RepairVehicle[]
  GasolineCost GasolineCost[]
  DrainTheOilVehicle DrainTheOilVehicle[]
  InstallmentsVehicle InstallmentsVehicle[]
  ImageVehicle ImageVehicle[]
  IncomeVehicle IncomeVehicle[]
  @@index([TenantId])
  @@index([VehicleId])
}

