// ======================================================================
// == FUEL BILL CHECKER (from โปรแกรมนำมัน) =============================
// ======================================================================

model FuelBill {
  id Int @id @default(autoincrement())
  lineUserId String
  employeeName String?
  imageUrl String?
  imageHash String?
  receiptNo String?
  station String?
  billDate String? // YYYY-MM-DD as read from the receipt
  billTime String? // HH:MM 24h
  fuelType String?
  liters Decimal? @db.Decimal(16,2)
  pricePerLiter Decimal? @db.Decimal(16,2)
  total Decimal? @db.Decimal(16,2)
  plate String?
  status String @default("ok") // ok | suspect | extract_failed
  suspectReasons String?
  createdAt DateTime @default(now())
  @@index([lineUserId])
  @@index([imageHash])
  @@index([receiptNo])
}

// Generic key/value app config (fuel line_admin_id, feature toggles, etc.)
model AppSetting {
  key String @id
  value String?
  updatedAt DateTime @default(now()) @updatedAt
}

// ======================================================================
// == DEBT / AR (from dhevadebt) ========================================
// ======================================================================

model DebtVersion {
  id String @id @default(cuid())
  fileName String
  uploadedAt DateTime @default(now())
  rowCount Int @default(0)
  totalAmount Decimal @db.Decimal(16,2) @default(0)
  isCurrent Boolean @default(false)
  records DebtRecord[]
  @@index([isCurrent])
}

model DebtRecord {
  id String @id @default(cuid())
  versionId String
  version DebtVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  docNo String
  docType String
  date String? // ISO YYYY-MM-DD (kept as string to match the source module)
  customer String
  project String
  taxId String
  dueDate String? // ISO YYYY-MM-DD
  branch String
  value Decimal @db.Decimal(16,2) @default(0)
  vat Decimal @db.Decimal(16,2) @default(0)
  total Decimal @db.Decimal(16,2) @default(0)
  depositRef String
  status String // Thai status union: รอวางบิล | วางบิลแล้ว | เปิดบิลแล้ว | ชำระแล้ว | ยกเลิก
  salesperson String
  @@index([versionId])
  @@index([docNo])
}
